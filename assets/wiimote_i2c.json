            },
            "ay": {
              "description": "10-bit reconstructed with lost LSB forced to 0",
              "expression_c": "((uint16_t)b[3] << 2) | (((b[5] >> 5) & 0x01) << 1)"
            },
            "az": {
              "description": "10-bit reconstructed with lost LSB forced to 0",
              "expression_c": "((uint16_t)(b[4] >> 1) << 3) | (((b[5] >> 6) & 0x03) << 1)"
            },
            "extension_connected": {
              "expression_c": "!!(b[4] & 0x01)"
            },
            "button_c_pressed": {
              "expression_c": "!(b[5] & 0x08)"
            },
            "button_z_pressed": {
              "expression_c": "!(b[5] & 0x04)"
            },
            "report_type_is_extension_data": {
              "expression_c": "!(b[5] & 0x02)"
            }
          },
          "byte_layout": [
            {
              "byte": 0,
              "bits_7_to_0": "SX[7:0]"
            },
            {
              "byte": 1,
              "bits_7_to_0": "SY[7:0]"
            },
            {
              "byte": 2,
              "bits_7_to_0": "AX[9:2]"
            },
            {
              "byte": 3,
              "bits_7_to_0": "AY[9:2]"
            },
            {
              "byte": 4,
              "bits_7_to_1": "AZ[9:3]",
              "bit_0": "ExtensionConnected"
            },
            {
              "byte": 5,
              "bits_7_to_6": "AZ[2:1]",
              "bit_5": "AY[1]",
              "bit_4": "AX[1]",
              "bit_3": "BC",
              "bit_2": "BZ",
              "bit_1": "ReportTypeFlag",
              "bit_0": "0"
            }
          ]
        },
        "classic_passthrough_report": {
          "name": "motion_plus_classic_passthrough_modified_classic_report",
          "activation_value_at_0xA600FE": "0x07",
          "length_bytes": 6,
          "interleaving_note": "MotionPlus and modified Classic Controller reports alternate. In passthrough mode, bit 1 of byte 5 distinguishes report type: 1 MotionPlus, 0 extension.",
          "fields": {
