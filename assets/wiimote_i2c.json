{
    "schema_name": "wiimote_extension_i2c_reference",
    "schema_version": "0.1.0",
    "notes": [
      "Wiimote is the I2C master. Extension/accessory is the I2C slave.",
      "Normal extension slave address is 0x52, 7-bit.",
      "Normal extensions expose a 0x100-byte virtual register block mapped at 0xA40000.",
      "Wii MotionPlus starts at 0xA60000 before activation, then can appear at 0xA40000 after activation.",
      "Most button bits are active-low: 0 means pressed, 1 means released.",
      "Layouts below describe decrypted/unencoded bytes. If using the new init sequence, extension type bytes and report data are normally unencrypted.",
      "Byte numbering is zero-based within the extension data payload read from the live-data register."
    ],
    "bus": {
      "physical_interface": "I2C",
      "i2c_speed_hz": 400000,
      "slave_address_7bit": "0x52",
      "logic_level_v": 3.3,
      "master": "Wiimote",
      "slave": "Extension controller",
      "normal_extension_register_base": "0xA40000",
      "motion_plus_register_base_before_activation": "0xA60000",
      "virtual_register_block_size_bytes": 256,
      "live_data_offset": "0x08",
      "live_data_address_normal_extension": "0xA40008",
      "id_address_normal_extension": "0xA400FA",
      "id_length_bytes": 6,
      "format_register": "0xA400FE"
    },
    "initialization": {
      "normal_extension_new_method": [
        {
          "operation": "write",
          "address": "0xA400F0",
          "data": ["0x55"],
          "meaning": "initialize / disable encryption path"
        },
        {
          "operation": "write",
          "address": "0xA400FB",
          "data": ["0x00"],
          "meaning": "complete new initialization method"
        },
        {
          "operation": "read",
          "address": "0xA400FA",
          "length": 6,
          "meaning": "read extension ID"
        }
      ],
      "normal_extension_old_method": [
        {
          "operation": "write",
          "address": "0xA40040",
          "data": ["0x00"],
          "meaning": "old encryption-byte initialization, less compatible"
        }
      ],
      "motion_plus_initialization": [
        {
          "operation": "write",
          "address": "0xA600F0",
          "data": ["0x55"],
          "meaning": "initialize MotionPlus at its pre-activation register space"
        },
        {
          "operation": "read",
          "address": "0xA600FA",
          "length": 6,
          "meaning": "read inactive MotionPlus ID"
        }
      ],
      "motion_plus_activation_modes": {
        "motion_plus_only": {
          "operation": "write",
          "address": "0xA600FE",
          "data": ["0x04"],
          "resulting_standard_id_at_0xA400FA": ["0x00", "0x00", "0xA4", "0x20", "0x04", "0x05"],
          "meaning": "activate MotionPlus as the active extension"
        },
        "motion_plus_plus_nunchuk_passthrough": {
          "operation": "write",
          "address": "0xA600FE",
          "data": ["0x05"],
          "resulting_standard_id_at_0xA400FA": ["0x00", "0x00", "0xA4", "0x20", "0x05", "0x05"],
          "meaning": "activate MotionPlus with Nunchuk passthrough interleaving"
        },
        "motion_plus_plus_classic_passthrough": {
          "operation": "write",
          "address": "0xA600FE",
          "data": ["0x07"],
          "resulting_standard_id_at_0xA400FA": ["0x00", "0x00", "0xA4", "0x20", "0x07", "0x05"],
          "meaning": "activate MotionPlus with Classic Controller passthrough interleaving"
        },
        "deactivate_motion_plus_return_to_passthrough_extension": {
          "operation": "write",
          "address": "0xA400F0",
          "data": ["0x55"],
          "meaning": "deactivate MotionPlus and expose extension plugged into MotionPlus passthrough port"
        }
      }
    },
    "extension_ids": {
      "nunchuk": {
        "id_bytes": ["0x00", "0x00", "0xA4", "0x20", "0x00", "0x00"],
        "id_address": "0xA400FA"
      },
      "classic_controller": {
        "id_bytes": ["0x00", "0x00", "0xA4", "0x20", "0x01", "0x01"],
        "id_address": "0xA400FA"
      },
      "classic_controller_pro": {
        "id_bytes": ["0x01", "0x00", "0xA4", "0x20", "0x01", "0x01"],
        "id_address": "0xA400FA"
      },
      "wii_motion_plus_inactive_at_standard_block": {
        "id_bytes": ["0x00", "0x00", "0xA4", "0x20", "0x00", "0x05"],
        "id_address": "0xA400FA"
      },
      "wii_motion_plus_inactive_at_motionplus_block": {
        "id_bytes": ["0x00", "0x00", "0xA6", "0x20", "0x00", "0x05"],
        "id_address": "0xA600FA"
      },
      "wii_motion_plus_active": {
        "id_bytes": ["0x00", "0x00", "0xA4", "0x20", "0x04", "0x05"],
        "id_address": "0xA400FA"
      },
      "wii_motion_plus_nunchuk_passthrough": {
        "id_bytes": ["0x00", "0x00", "0xA4", "0x20", "0x05", "0x05"],
        "id_address": "0xA400FA"
      },
      "wii_motion_plus_classic_passthrough": {
        "id_bytes": ["0x00", "0x00", "0xA4", "0x20", "0x07", "0x05"],
        "id_address": "0xA400FA"
      }
    },
    "encryption": {
      "new_init_disables_encryption": true,
      "encrypted_mode_formula": "decrypted_byte = ((encrypted_byte ^ table1[address % 8]) + table2[address % 8]) & 0xFF",
      "zero_key_table_note": "If the host key is 16 zero bytes, table1[x] and table2[x] are all 0x97 according to WiiBrew.",
      "recommendation": "Use the new init method unless deliberately testing old-mode compatibility."
    },
    "extensions": {
      "nunchuk": {
        "report": {
          "name": "nunchuk_6_byte_report",
          "read_address": "0xA40008",
          "length_bytes": 6,
          "fields": {
            "sx": {
              "description": "joystick X",
              "bits": 8,
              "expression_c": "b[0]",
              "range_nominal": [0, 255],
              "range_typical_physical": [35, 228],
              "center_typical": 128
            },
            "sy": {
              "description": "joystick Y",
              "bits": 8,
              "expression_c": "b[1]",
              "range_nominal": [0, 255],
              "range_typical_physical": [27, 220],
              "center_typical": 128
            },
            "ax": {
              "description": "accelerometer X, 10-bit",
              "bits": 10,
              "expression_c": "((uint16_t)b[2] << 2) | ((b[5] >> 2) & 0x03)",
              "range_nominal": [0, 1023]
            },
            "ay": {
              "description": "accelerometer Y, 10-bit",
              "bits": 10,
              "expression_c": "((uint16_t)b[3] << 2) | ((b[5] >> 4) & 0x03)",
              "range_nominal": [0, 1023]
            },
            "az": {
              "description": "accelerometer Z, 10-bit",
              "bits": 10,
              "expression_c": "((uint16_t)b[4] << 2) | ((b[5] >> 6) & 0x03)",
              "range_nominal": [0, 1023]
            },
            "button_c_pressed": {
              "description": "C button, active low",
              "bits": 1,
              "expression_c": "!(b[5] & 0x02)"
            },
            "button_z_pressed": {
              "description": "Z button, active low",
              "bits": 1,
              "expression_c": "!(b[5] & 0x01)"
            }
          },
          "byte_layout": [
            {
              "byte": 0,
              "bits_7_to_0": "SX[7:0]"
            },
            {
              "byte": 1,
              "bits_7_to_0": "SY[7:0]"
            },
            {
              "byte": 2,
              "bits_7_to_0": "AX[9:2]"
            },
            {
              "byte": 3,
              "bits_7_to_0": "AY[9:2]"
            },
            {
              "byte": 4,
              "bits_7_to_0": "AZ[9:2]"
            },
            {
              "byte": 5,
              "bits_7_to_0": "AZ[1:0], AY[1:0], AX[1:0], BC, BZ"
            }
          ]
        }
      },
      "classic_controller": {
        "data_format_register": "0xA400FE",
        "supported_formats": {
