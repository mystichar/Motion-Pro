      "wii_motion_plus": {
        "pre_activation": {
          "register_base": "0xA60000",
          "id_address": "0xA600FA",
          "inactive_id": ["0x00", "0x00", "0xA6", "0x20", "0x00", "0x05"],
          "activation_register": "0xA600FE"
        },
        "active_report": {
          "name": "wii_motion_plus_6_byte_gyro_report",
          "read_address": "0xA40008",
          "alternate_read_address_note": "Some docs mention 0xA40000 in some cases.",
          "length_bytes": 6,
          "fields": {
            "yaw_down_speed_raw": {
              "description": "14-bit raw yaw/down angular-rate channel",
              "bits": 14,
              "expression_c": "((uint16_t)b[0]) | (((uint16_t)b[3] & 0xFC) << 6)"
            },
            "roll_left_speed_raw": {
              "description": "14-bit raw roll/left angular-rate channel",
              "bits": 14,
              "expression_c": "((uint16_t)b[1]) | (((uint16_t)b[4] & 0xFC) << 6)"
            },
            "pitch_left_speed_raw": {
              "description": "14-bit raw pitch/left angular-rate channel",
              "bits": 14,
              "expression_c": "((uint16_t)b[2]) | (((uint16_t)b[5] & 0xFC) << 6)"
            },
            "yaw_slow_mode": {
              "description": "1 when slow or still, 0 when fast",
              "expression_c": "!!(b[3] & 0x02)"
            },
            "pitch_slow_mode": {
              "description": "1 when slow or still, 0 when fast",
              "expression_c": "!!(b[3] & 0x01)"
            },
            "roll_slow_mode": {
              "description": "1 when slow or still, 0 when fast",
              "expression_c": "!!(b[4] & 0x02)"
            },
            "extension_connected_to_motionplus_port": {
              "description": "1 when extension is connected to MotionPlus passthrough port",
              "expression_c": "!!(b[4] & 0x01)"
            },
            "report_type_motionplus_vs_passthrough": {
              "description": "In passthrough/interleaved mode, bit 1 of byte 5 is used to tell MotionPlus report vs extension report. WiiBrew: 1 means MotionPlus data, 0 means extension data.",
              "expression_c": "!!(b[5] & 0x02)"
            },
            "reserved_or_constant_bit0": {
              "description": "Documented as 0 in normal MotionPlus layout.",
              "expression_c": "b[5] & 0x01"
            }
          },
          "byte_layout": [
            {
              "byte": 0,
              "bits_7_to_0": "YawDownSpeed[7:0]"
            },
            {
              "byte": 1,
              "bits_7_to_0": "RollLeftSpeed[7:0]"
            },
            {
              "byte": 2,
              "bits_7_to_0": "PitchLeftSpeed[7:0]"
            },
            {
              "byte": 3,
              "bits_7_to_2": "YawDownSpeed[13:8]",
              "bit_1": "YawSlowMode",
              "bit_0": "PitchSlowMode"
            },
            {
              "byte": 4,
              "bits_7_to_2": "RollLeftSpeed[13:8]",
              "bit_1": "RollSlowMode",
              "bit_0": "ExtensionConnected"
            },
            {
              "byte": 5,
              "bits_7_to_2": "PitchLeftSpeed[13:8]",
              "bit_1": "MotionPlusReportFlagInPassthrough_or_1",
              "bit_0": "0"
            }
          ],
          "calibration": {
            "calibration_base": "0xA60020",
            "zero_raw_while_still_typical": "about 0x1F7F, but calibrate on startup",
            "slow_bit_meaning": "1 means slow or still, 0 means fast",
            "deg_per_second_note": "WiiBrew suggests dividing slow-mode delta by approximately 13.768 units per deg/s, with fast mode multiplied by about 2000/440 relative to slow."
          }
        },
        "nunchuk_passthrough_report": {
          "name": "motion_plus_nunchuk_passthrough_modified_nunchuk_report",
          "activation_value_at_0xA600FE": "0x05",
          "length_bytes": 6,
          "interleaving_note": "MotionPlus and modified Nunchuk reports alternate. In passthrough mode, bit 1 of byte 5 distinguishes report type: 1 MotionPlus, 0 extension.",
          "fields": {
            "sx": {
              "expression_c": "b[0]"
            },
            "sy": {
              "expression_c": "b[1]"
            },
            "ax": {
